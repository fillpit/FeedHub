{
  "name": "feed_sub",
  "version": "0.3.0",
  "description": "Feed Sub",
  "author": "Antigravity",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "init": "node scripts/init.mjs",
    "build": "pnpm -r build",
    "electron:dev": "pnpm build && electron .",
    "electron:build": "pnpm build && electron-builder --config electron/builder.config.js",
    "lint": "eslint . --cache --cache-location .cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint/"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "prompts": "^2.4.2",
    "typescript-eslint": "^8.59.1"
  }
}