{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "domhandler": ["../node_modules/.pnpm/domhandler@5.0.3/node_modules/domhandler"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
